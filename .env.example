MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_PORT=3306
MYSQL_DATABASE=password_manager

MASTER_KEY_SALT=your_random_salt_here_min_32_chars
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================================
# LLM Configuration - Support Multiple Providers
# ============================================================
#
# Supported Providers:
# 1. openai: OpenAI official or OpenAI-compatible APIs
# 2. doubao: Doubao/DeepSeek via Ark API (ark.cn-beijing.volces.com)
# 3. custom: Custom OpenAI-compatible services
#

# Example 1: Doubao/DeepSeek (Recommended for Chinese users)
LLM_PROVIDER=doubao
LLM_MODEL=deepseek-v3-250324
LLM_API_KEY=your_doubao_api_key_here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/

# Example 2: OpenAI Official (Uncomment to use)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-3.5-turbo
# LLM_API_KEY=sk-your_openai_api_key_here
# LLM_BASE_URL=  # Leave empty to use OpenAI's official endpoint

# Example 3: SENSEAUTO (Legacy, still supported)
# LLM_PROVIDER=custom
# LLM_MODEL=gpt-3.5-turbo
# LLM_API_KEY=token-your_senseauto_key_here
# LLM_BASE_URL=http://your_senseauto_server:port/v1

# Backward Compatibility (Deprecated, use LLM_* variables instead)
# SENSEAUTO_OPENAI_API_KEY=
# SENSEAUTO_OPENAI_API_BASE=
# SENSEAUTO_OPENAI_MODEL=